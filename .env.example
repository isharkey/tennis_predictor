APP_BASIC_AUTH_USER=choose_a_private_username
APP_BASIC_AUTH_PASSWORD=choose_a_private_password

SOFASCORE_RAPIDAPI_KEY=put_your_rapidapi_key_here
SOFASCORE_RAPIDAPI_HOST=sofascore6.p.rapidapi.com
SOFASCORE_RAPIDAPI_BASE_URL=https://sofascore6.p.rapidapi.com/api/sofascore/v1
# Optional per-player season stats endpoint template.
# Example: /player/statistics/seasons?player_id={playerId}
SOFASCORE_PLAYER_STATS_PATH_TEMPLATE=

JJRM365_TENNIS_RAPIDAPI_KEY=put_your_rapidapi_key_here
JJRM365_TENNIS_RAPIDAPI_HOST=tennis-api-atp-wta-itf.p.rapidapi.com
JJRM365_TENNIS_RAPIDAPI_BASE_URL=https://tennis-api-atp-wta-itf.p.rapidapi.com

# Optional named endpoint shortcuts from the JJRM365 RapidAPI docs.
JJRM365_TENNIS_ENDPOINT_TODAY_MATCHES=/put/today/matches/path/here
JJRM365_TENNIS_ENDPOINT_PLAYER_SEARCH=/put/player/search/path/here
JJRM365_TENNIS_ENDPOINT_MATCH_DETAIL=/put/match/detail/path/here
# Optional per-player stats endpoint template.
# Example: /tennis/v2/extend/api/player/{playerId}/stats
JJRM365_TENNIS_PLAYER_STATS_PATH_TEMPLATE=

ALLSPORTS_TENNIS_RAPIDAPI_KEY=put_your_rapidapi_key_here
ALLSPORTS_TENNIS_RAPIDAPI_HOST=tennisapi1.p.rapidapi.com
ALLSPORTS_TENNIS_RAPIDAPI_BASE_URL=https://tennisapi1.p.rapidapi.com
# Optional per-player historical profile endpoint template.
# Example: /api/tennis/player/{playerId}/statistics
ALLSPORTS_TENNIS_PLAYER_STATS_PATH_TEMPLATE=
# Optional cap to protect API quota when pulling per-player history.
ALLSPORTS_TENNIS_PLAYER_STATS_MAX_PULLS=40

LIVESCORE6_RAPIDAPI_KEY=put_your_rapidapi_key_here
LIVESCORE6_RAPIDAPI_HOST=livescore6.p.rapidapi.com
LIVESCORE6_RAPIDAPI_BASE_URL=https://livescore6.p.rapidapi.com

TENNIS_API5_RAPIDAPI_KEY=put_your_rapidapi_key_here
TENNIS_API5_RAPIDAPI_HOST=tennis-api5.p.rapidapi.com
TENNIS_API5_RAPIDAPI_BASE_URL=https://tennis-api5.p.rapidapi.com
